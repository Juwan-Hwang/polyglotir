# Copy to .env and fill in your API keys

# ── OpenAI-compatible proxy (local) ──────────────────────────────────
# Works with any OpenAI-compatible endpoint.
# For local proxies, the API key can be anything.
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://localhost:8787/v1

# ── Official API keys (optional) ─────────────────────────────────────
# Only needed if you want to test official OpenAI/Anthropic/Google models
# directly (not through the proxy).
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=   (leave empty for official endpoint)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
