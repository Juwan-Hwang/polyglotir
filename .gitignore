# SILP .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.*
!.env.example

# SILP compile lock (artifacts)
.silp/compile.lock

# Large files (keep under repo limit)
docs/conversation_transcript.txt

# pytest
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Data: keep processed data, ignore nothing in data/ except backups
data/raw/phase3_heartbeat_backup_810/

# Paper (not tracked; managed outside repo)
paper.md

# Temporary verification/debug scripts
scripts/_*.py
